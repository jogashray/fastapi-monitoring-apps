# FastAPI Metrics App — example environment configuration
# Copy this file to `.env` and adjust values for your environment.

# Application
APP_NAME=fastapi-metrics-app
APP_VERSION=1.0.0

# Metrics endpoint path
METRICS_ENDPOINT=/metrics

# System metrics collection interval (seconds)
SYSTEM_METRICS_INTERVAL=5

# Enable default Prometheus collectors (process, platform, GC)
ENABLE_DEFAULT_METRICS=true

# HTTP duration histogram buckets (seconds)
HTTP_HISTOGRAM_BUCKETS=0.005,0.01,0.025,0.05,0.1,0.25,0.5,1.0,2.5,5.0,10.0

# Request size histogram buckets (bytes)
REQUEST_SIZE_BUCKETS=100,1024,10240,102400,1048576,10485760

# Response size histogram buckets (bytes)
RESPONSE_SIZE_BUCKETS=100,1024,10240,102400,1048576,10485760

# Maximum items in /data in-memory store
MAX_DATA_ITEMS=1000

# -----------------------------------------------------------
# Host-side port bindings for the docker-compose stack.
# Change any of these if the default port is already in use
# on your device (e.g. another Grafana install on :3000).
# Container-side ports stay fixed.
# -----------------------------------------------------------
FASTAPI_PORT=8000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000